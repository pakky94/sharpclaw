{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Debugging": {
    "Enabled": false
  },
  "WebSearch": {
    "ActiveProvider": "Searxng",
    "Brave": {
      "ApiKey": "",
      "BaseUrl": "https://api.search.brave.com/res/v1",
      "MaxResults": 10,
      "Country": "US"
    },
    "Searxng": {
      "BaseUrl": "http://localhost:8080",
      "MaxResults": 10,
      "DefaultLanguage": "en-US",
      "Engines": ""
    }
  }
}
